# ── Options Trading Bot — Backend Environment Variables ──────────────────────
# Copy this file to .env and fill in values.
# NEVER commit .env to git.

# App
APP_ENV=development
SECRET_KEY=replace-this-with-a-long-random-string-at-least-32-chars

# CORS — frontend URL(s) allowed to call the API
# Local development:
ALLOWED_ORIGINS=["http://localhost:3000"]
# Production (update after Vercel deployment):
# ALLOWED_ORIGINS=["https://your-options-bot.vercel.app"]

# Database
# SQLite (default — zero setup, works on Render free tier)
DATABASE_URL=sqlite+aiosqlite:///./trading_bot.db
# MongoDB Atlas (optional — better for production)
# MONGODB_URL=mongodb+srv://user:password@cluster.mongodb.net/options_bot

# ── Trading Parameters ────────────────────────────────────────────────────────
DEFAULT_SYMBOL=NIFTY
DEFAULT_CAPITAL=100000
RISK_PER_TRADE_PCT=1.5
DAILY_LOSS_CAP_PCT=3.0
REWARD_RATIO=2.0
DATA_FETCH_INTERVAL=60

# ── Broker (Phase 2 — Live Trading Only) ─────────────────────────────────────
# Options: "none" (paper only), "angel" (Angel One SmartAPI — FREE)
BROKER=none

# Angel One SmartAPI (free — https://smartapi.angelbroking.com)
BROKER_API_KEY=
BROKER_CLIENT_CODE=
BROKER_TOTP_SECRET=

# Zerodha Kite (paid — ₹2000/month, not recommended for free setup)
# BROKER_API_KEY=
# BROKER_API_SECRET=
# BROKER_ACCESS_TOKEN=
